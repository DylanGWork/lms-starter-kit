# Database
POSTGRES_USER=lms
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=lms_platform
DATABASE_URL=postgresql://lms:change_this_password@postgres:5432/lms_platform

# NextAuth
NEXTAUTH_SECRET=generate_a_long_random_string_here
NEXTAUTH_URL=https://training.example.internal
NEXTAUTH_URL_INTERNAL=http://127.0.0.1:3000
AUTH_TRUST_HOST=true

# File uploads
UPLOAD_DIR=/app/uploads

# Environment
NODE_ENV=production

# Starter identity
APP_DISPLAY_NAME=LMS Starter Kit
APP_SUPPORT_NAME=Platform Admin
APP_SUPPORT_EMAIL=admin@example.internal

# Optional: For future S3/MinIO storage
# STORAGE_PROVIDER=local
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
